{
  "name": "vividforge",
  "version": "2.0.0",
  "description": "AI-powered creative ideation & multimodal platform combining concept generation with storytelling, design, and interactive experiences. Powered by IBM watsonx.ai and Granite models.",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "echo \"Tests will be implemented\" && exit 0",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "keywords": [
    "ai",
    "creative",
    "storytelling",
    "design",
    "multimodal",
    "ibm-bob",
    "ibm-watsonx",
    "granite",
    "concept-generation",
    "visual-design"
  ],
  "author": "Paul Moore",
  "license": "MIT",
  "dependencies": {
    "@ibm-cloud/watsonx-ai": "^1.7.13",
    "ibm-cloud-sdk-core": "^5.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "marked": "^11.0.0",
    "dompurify": "^3.0.6",
    "isomorphic-dompurify": "^2.9.0",
    "uuid": "^14.0.0",
    "elevenlabs-node": "^1.0.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.1.0"
  }
}